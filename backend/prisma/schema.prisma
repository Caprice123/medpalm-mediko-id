generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model constants {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  value      String
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  @@index([key])
}

model credit_plans {
  id                  Int                   @id @default(autoincrement())
  name                String
  description         String?
  credits             Int
  price               Decimal               @db.Decimal(10, 2)
  is_active           Boolean               @default(true)
  is_popular          Boolean               @default(false)
  discount            Int                   @default(0)
  order               Int                   @default(0)
  created_at          DateTime              @default(now())
  updated_at          DateTime              @default(now())
  credit_transactions credit_transactions[]
}

model credit_transactions {
  id                Int           @id @default(autoincrement())
  user_id           Int
  user_credit_id    Int
  type              String
  amount            Decimal       @db.Decimal(10, 2)
  balance_before    Decimal       @db.Decimal(10, 2)
  balance_after     Decimal       @db.Decimal(10, 2)
  description       String?
  credit_plan_id    Int?
  session_id        Int?
  payment_status    String?
  payment_method    String?
  payment_reference String?
  created_at        DateTime      @default(now())
  credit_plans      credit_plans? @relation(fields: [credit_plan_id], references: [id])
  user_credits      user_credits  @relation(fields: [user_credit_id], references: [id])

  @@index([payment_status])
  @@index([type])
  @@index([user_credit_id])
  @@index([user_id])
}

model exercise_questions {
  id              Int             @id @default(autoincrement())
  topic_id        Int
  question        String
  answer          String
  explanation     String?
  order           Int             @default(0)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @default(now())
  exercise_topics exercise_topics @relation(fields: [topic_id], references: [id])

  @@index([order])
  @@index([topic_id])
}

model exercise_sessions {
  id                       Int      @id @default(autoincrement())
  user_learning_session_id Int      @unique
  exercise_topic_id        Int?
  total_question           Int
  credits_used             Int      @default(0)
  number_of_attempts       Int      @default(0)
  created_at               DateTime @default(now())
  updated_at               DateTime @default(now())

  exercise_session_attempts  exercise_session_attempts[]
  user_learning_session      user_learning_sessions       @relation(fields: [user_learning_session_id], references: [id])
  exercise_session_questions exercise_session_questions[]
  exercise_topic             exercise_topics?             @relation(fields: [exercise_topic_id], references: [id])

  @@index([user_learning_session_id])
  @@index([exercise_topic_id])
}

model exercise_session_questions {
  id                  Int      @id @default(autoincrement())
  exercise_session_id Int
  question_text       String // Snapshot of question at time of session
  answer_text         String // Snapshot of answer at time of session
  explanation         String // Snapshot of explanation at time of session
  order               Int
  created_at          DateTime @default(now())

  exercise_session         exercise_sessions          @relation(fields: [exercise_session_id], references: [id])
  exercise_session_answers exercise_session_answers[]

  @@index([order])
}

model exercise_session_attempts {
  id                  Int       @id @default(autoincrement())
  exercise_session_id Int
  attempt_number      Int       @default(1)
  status              String    @default("not_started")
  correct_question    Int?
  total_question      Int?
  score               Int       @default(0)
  started_at          DateTime  @default(now())
  completed_at        DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now())

  exercise_session_answers exercise_session_answers[]
  exercise_session         exercise_sessions          @relation(fields: [exercise_session_id], references: [id])

  @@index([exercise_session_id])
  @@index([started_at])
  @@index([status])
}

model exercise_session_answers {
  id                           Int      @id @default(autoincrement())
  exercise_session_attempt_id  Int
  exercise_session_question_id Int
  user_answer                  String
  is_correct                   Boolean
  answered_at                  DateTime @default(now())
  time_taken_seconds           Int?

  exercise_session_attempts  exercise_session_attempts  @relation(fields: [exercise_session_attempt_id], references: [id])
  exercise_session_questions exercise_session_questions @relation(fields: [exercise_session_question_id], references: [id])

  @@index([answered_at])
  @@index([exercise_session_attempt_id])
  @@index([exercise_session_question_id])
}

model exercise_topic_tags {
  id              Int             @id @default(autoincrement())
  topic_id        Int
  tag_id          Int
  created_at      DateTime        @default(now())
  tags            tags            @relation(fields: [tag_id], references: [id])
  exercise_topics exercise_topics @relation(fields: [topic_id], references: [id])

  @@unique([topic_id, tag_id])
  @@index([tag_id])
  @@index([topic_id])
}

model exercise_topics {
  id             Int      @id @default(autoincrement())
  unique_id      String   @unique @default(uuid())
  title          String
  description    String?
  content_type   String
  content        String?
  question_count Int?
  status         String   @default("draft")
  is_deleted     Boolean  @default(false)
  deleted_at     DateTime?
  created_by     Int
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())

  exercise_session    exercise_sessions[]
  exercise_questions  exercise_questions[]
  exercise_topic_tags exercise_topic_tags[]

  @@index([created_by])
  @@index([status])
  @@index([is_deleted])
  @@index([title(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops"))], type: Gin, map: "exercise_topics_search_gin_idx")
}

model tags {
  id           Int      @id @default(autoincrement())
  name         String
  tag_group_id Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  tag_group tag_groups? @relation(fields: [tag_group_id], references: [id])

  exercise_topic_tags          exercise_topic_tags[]
  flashcard_deck_tags          flashcard_deck_tags[]
  summary_note_tags            summary_note_tags[]
  calculator_topic_tags        calculator_topic_tags[]
  diagnostic_quiz_tags            diagnostic_quiz_tags[]
  anatomy_quiz_tags               anatomy_quiz_tags[]
  atlas_model_tags             atlas_model_tags[]
  mcq_topic_tags               mcq_topic_tags[]
  osce_topic_tags              osce_topic_tags[]
  osce_session_topic_snapshots osce_session_tag_snapshots[]
  challenge_tags               challenge_tags[]

  @@unique([name, tag_group_id])
}

model tag_groups {
  id         Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  tags tags[]

  @@unique([name])
}

model user_learning_sessions {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String
  type       String   @default("exercise")
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  exercise_session     exercise_sessions?
  flashcard_session    flashcard_sessions?
  summary_note_session summary_note_sessions?

  @@index([title])
  @@index([type])
  @@index([user_id])
}

model flashcard_decks {
  id              Int      @id @default(autoincrement())
  unique_id       String   @unique @default(uuid())
  title           String
  description     String?
  content_type    String
  content         String?
  flashcard_count Int?
  status          String   @default("draft")
  is_deleted      Boolean  @default(false)
  deleted_at      DateTime?
  created_by      Int
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  flashcard_cards              flashcard_cards[]
  flashcard_deck_tags          flashcard_deck_tags[]
  flashcard_sessions           flashcard_sessions[]
  summary_note_flashcard_decks summary_note_flashcard_decks[]

  @@index([created_by])
  @@index([status])
  @@index([is_deleted])
  @@index([title(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops"))], type: Gin, map: "flashcard_decks_search_gin_idx")
}

model flashcard_cards {
  id         Int            @id @default(autoincrement())
  deck_id    Int?
  node_id    Int?
  front      String
  back       String
  image_url  String?
  order      Int            @default(0)
  is_deleted Boolean        @default(false)
  created_at DateTime       @default(now())
  updated_at DateTime       @default(now())

  flashcard_decks flashcard_decks? @relation(fields: [deck_id], references: [id])
  feature_nodes   feature_nodes?   @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@index([deck_id])
  @@index([node_id])
  @@index([is_deleted])
}

model flashcard_deck_tags {
  id         Int      @id @default(autoincrement())
  deck_id    Int
  tag_id     Int
  created_at DateTime @default(now())

  flashcard_decks flashcard_decks @relation(fields: [deck_id], references: [id])
  tags            tags            @relation(fields: [tag_id], references: [id])

  @@unique([deck_id, tag_id])
  @@index([deck_id])
  @@index([tag_id])
}

model flashcard_sessions {
  id                       Int      @id @default(autoincrement())
  user_learning_session_id Int      @unique
  flashcard_deck_id        Int?
  total_cards              Int
  credits_used             Int      @default(0)
  created_at               DateTime @default(now())
  updated_at               DateTime @default(now())

  user_learning_session   user_learning_sessions    @relation(fields: [user_learning_session_id], references: [id])
  flashcard_deck          flashcard_decks?          @relation(fields: [flashcard_deck_id], references: [id])
  flashcard_session_cards flashcard_session_cards[]

  @@index([user_learning_session_id])
  @@index([flashcard_deck_id])
}

model flashcard_session_cards {
  id                   Int      @id @default(autoincrement())
  flashcard_session_id Int
  original_card_id     Int? // references flashcard_cards.id for progress tracking
  front_text           String
  back_text            String
  order                Int
  created_at           DateTime @default(now())

  flashcard_session flashcard_sessions @relation(fields: [flashcard_session_id], references: [id])

  @@index([flashcard_session_id])
  @@index([order])
  @@index([original_card_id])
}

// Track user progress per card across all sessions
model user_card_progress {
  id              Int      @id @default(autoincrement())
  user_id         Int
  card_id         Int // references flashcard_cards.id
  times_correct   Int      @default(0)
  times_incorrect Int      @default(0)
  last_reviewed   DateTime @default(now())
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  @@unique([user_id, card_id])
  @@index([user_id])
  @@index([card_id])
}

model user_review_states {
  id           Int      @id @default(autoincrement())
  user_id      Int
  record_type  String
  record_id    Int
  interval     Float    @default(1)
  ease_factor  Float    @default(2.5)
  due_date     DateTime
  review_count Int      @default(0)
  last_rating  String
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  @@unique([user_id, record_type, record_id])
  @@index([user_id])
  @@index([due_date])
  @@index([record_type, record_id])
  @@index([user_id, record_type, due_date, id])
}

model user_feature_statistics {
  user_id         Int
  feature         String
  statistic_type  String
  statistic_count Int      @default(0)
  updated_at      DateTime @default(now()) @updatedAt

  @@id([user_id, feature, statistic_type])
}

model user_review_custom_sessions {
  id                 Int      @id @default(autoincrement())
  user_id            Int
  name               String
  record_type        String   @default("flashcard_card")
  node_id            Int?
  department_node_id Int?
  mode               String   @default("due_today")
  card_limit         Int      @default(20)
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  @@index([user_id])
}

model review_sessions {
  id                  Int      @id @default(autoincrement())
  unique_id           String   @unique @default("")
  user_id             Int
  type                String   @default("all")
  record_type         String   @default("flashcard_card")
  mode                String   @default("due_today")
  node_ids            String?
  department_node_ids String?
  last_rating         String?
  card_limit          Int      @default(20)
  card_ids            String?
  created_at          DateTime @default(now())

  @@index([user_id])
  @@index([user_id, created_at(sort: Desc)])
}

model user_question_progress {
  id              Int      @id @default(autoincrement())
  user_id         Int
  question_id     Int // references exercise_questions.id
  topic_id        Int // references exercise_topics.id
  times_correct   Int      @default(0)
  times_incorrect Int      @default(0)
  last_reviewed   DateTime @default(now())
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  @@unique([user_id, question_id])
  @@index([user_id])
  @@index([question_id])
  @@index([topic_id])
}

model user_sessions {
  id                       Int       @id @default(autoincrement())
  user_id                  Int
  token                    String    @unique
  refresh_token            String?   @unique
  refresh_token_expires_at DateTime?
  is_active                Boolean   @default(true)
  user_agent               String?
  ip_address               String?
  expires_at               DateTime
  last_active_at           DateTime  @default(now())
  created_at               DateTime  @default(now())

  @@index([token])
  @@index([refresh_token])
  @@index([user_id])
}

model users {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String?
  picture     String?
  google_id   String?  @unique
  role        String   @default("user")
  is_active   Boolean  @default(true)
  permissions           Json? // User-specific permissions for admin features
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  user_credits                  user_credits[]
  user_subscription             user_subscriptions[]
  user_purchases                user_purchases[]
  chatbot_conversations         chatbot_conversations[]
  user_chatbot_settings         user_chatbot_settings?
  skripsi_sets                  skripsi_sets[]
  osce_sessions                 osce_sessions[]
  user_feature_subscriptions    user_feature_subscriptions[]
  challenge_sessions            challenge_sessions[]
  user_profile                  user_profiles?
  user_recently_viewed          user_recently_viewed[]
  user_favorites                user_favorites[]
}

model user_profiles {
  id           Int      @id @default(autoincrement())
  user_id      Int      @unique
  phone_number String?
  university   String?
  is_complete  Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model feature_nodes {
  id             Int             @id @default(autoincrement())
  name           String
  slug           String          @unique
  parent_id      Int?
  node_type      String?
  visibility     String          @default("general")
  classification String?
  layer          Int?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @default(now())

  parent   feature_nodes?  @relation("FeatureNodeChildren", fields: [parent_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  children feature_nodes[] @relation("FeatureNodeChildren")

  feature_node_records  feature_node_records[]
  flashcard_cards       flashcard_cards[]
  node_statistics       node_statistics[]
  user_node_progress    user_node_progress[]

  @@index([parent_id])
  @@index([name])
  @@index([layer])
}

model node_statistics {
  node_id     Int
  record_type String
  total_count Int      @default(0)
  updated_at  DateTime @default(now()) @updatedAt

  feature_nodes feature_nodes @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@id([node_id, record_type])
}

model user_node_progress {
  id           Int      @id @default(autoincrement())
  user_id      Int
  node_id      Int
  feature_type String
  again_count  Int      @default(0)
  hard_count   Int      @default(0)
  good_count   Int      @default(0)
  easy_count   Int      @default(0)
  updated_at   DateTime @default(now())

  feature_nodes feature_nodes @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@unique([user_id, node_id, feature_type])
  @@index([user_id, feature_type])
}

model feature_node_records {
  id          Int           @id @default(autoincrement())
  node_id     Int
  record_type String
  record_id   Int
  created_at  DateTime      @default(now())
  updated_at  DateTime      @default(now())

  node feature_nodes @relation(fields: [node_id], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([node_id, record_type, record_id])
  @@index([record_type, record_id])
}

model content_relations {
  id          Int      @id @default(autoincrement())
  source_type String
  source_id   Int
  target_type String
  target_id   Int
  order       Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  @@unique([source_type, source_id, target_type, target_id])
  @@index([source_type, source_id])
  @@index([target_type, target_id])
}

model user_feature_subscriptions {
  id         Int       @id @default(autoincrement())
  user_id    Int
  feature    String    // 'exercise' | 'flashcard' | 'calculator' | 'diagnostic' | 'anatomy' | 'mcq' | 'chatbot' | 'skripsi' | 'oscePractice' | 'summaryNotes' | 'atlas'
  start_date DateTime  @default(now())
  end_date   DateTime
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())

  user users @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([feature])
  @@index([user_id, feature])
  @@index([end_date])
  @@index([start_date])
}

model user_subscriptions {
  id         Int      @id @default(autoincrement())
  user_id    Int
  pricing_plan_id Int?
  start_date DateTime
  end_date   DateTime
  status     String   @default("active") // 'active', 'not_active', 'expired'
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])
  pricing_plan pricing_plans? @relation(fields: [pricing_plan_id], references: [id])

  @@index([user_id, start_date, end_date])
  @@index([pricing_plan_id])
  @@index([status])
}

model user_credits {
  id          Int       @id @default(autoincrement())
  user_id     Int
  balance     Decimal   @default(0) @db.Decimal(10, 2)
  credit_type String    @default("permanent") // permanent, expiring
  expires_at  DateTime? // null = never expires
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())

  user                users                 @relation(fields: [user_id], references: [id])
  credit_transactions credit_transactions[]

  @@index([user_id])
  @@index([user_id, credit_type])
  @@index([expires_at])
}

// ============= Chatbot Settings =============

model chatbot_research_domains {
  id           Int      @id @default(autoincrement())
  domain       String   @unique
  journal_name String   @default("")
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  @@index([is_active])
}

model chatbot_journal_names {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

model user_chatbot_settings {
  id                    Int      @id @default(autoincrement())
  user_id               Int      @unique
  selected_domains      Json     @default("[]") // Array of domain strings selected from admin list
  selected_journals     Json     @default("[]") // Array of journal name strings for tutor users
  domain_filter_enabled Boolean  @default(true)
  latest_years          Int?     // "last N years" filter, computed at query time (takes priority over year_from/year_to)
  year_from             Int?     // range start year (used when latest_years is null)
  year_to               Int?     // range end year (used when latest_years is null; null = up to now)
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  user users @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

// ============= Summary Notes Feature =============

model summary_notes {
  id               Int     @id @default(autoincrement())
  unique_id        String  @unique @default(uuid())
  title            String
  description      String?
  content          String  @db.Text // BlockNote JSON format
  markdown_content String? @db.Text // Markdown format for testing/export

  status     String   @default("draft")
  is_deleted Boolean  @default(false)
  deleted_at DateTime?
  created_by Int
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  summary_note_tags            summary_note_tags[]
  summary_note_sessions        summary_note_sessions[]
  summary_note_flashcard_decks summary_note_flashcard_decks[]
  summary_note_mcq_topics      summary_note_mcq_topics[]

  @@index([created_by])
  @@index([status])
  @@index([is_deleted])
  @@index([title(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops"))], type: Gin, map: "summary_notes_search_gin_idx")
}

model summary_note_tags {
  id              Int      @id @default(autoincrement())
  summary_note_id Int
  tag_id          Int
  created_at      DateTime @default(now())

  summary_note summary_notes @relation(fields: [summary_note_id], references: [id])
  tags         tags          @relation(fields: [tag_id], references: [id])

  @@unique([summary_note_id, tag_id])
  @@index([summary_note_id])
  @@index([tag_id])
}

model summary_note_sessions {
  id                       Int      @id @default(autoincrement())
  user_learning_session_id Int      @unique
  summary_note_id          Int
  credits_used             Int      @default(0)
  viewed_at                DateTime @default(now())
  created_at               DateTime @default(now())

  user_learning_session user_learning_sessions @relation(fields: [user_learning_session_id], references: [id])
  summary_note          summary_notes          @relation(fields: [summary_note_id], references: [id])

  @@index([user_learning_session_id])
  @@index([summary_note_id])
}

model summary_note_flashcard_decks {
  id                 Int      @id @default(autoincrement())
  summary_note_id    Int
  flashcard_deck_id  Int
  created_at         DateTime @default(now())

  summary_note    summary_notes   @relation(fields: [summary_note_id], references: [id])
  flashcard_deck  flashcard_decks @relation(fields: [flashcard_deck_id], references: [id])

  @@unique([summary_note_id, flashcard_deck_id])
  @@index([summary_note_id])
  @@index([flashcard_deck_id])
}

model summary_note_mcq_topics {
  id              Int      @id @default(autoincrement())
  summary_note_id Int
  mcq_topic_id    Int
  created_at      DateTime @default(now())

  summary_note summary_notes @relation(fields: [summary_note_id], references: [id])
  mcq_topic    mcq_topics    @relation(fields: [mcq_topic_id], references: [id])

  @@unique([summary_note_id, mcq_topic_id])
  @@index([summary_note_id])
  @@index([mcq_topic_id])
}

// ============= Platform Statistics =============

model statistics {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  value      Int      @default(0)
  updated_at DateTime @default(now()) @updatedAt

  @@index([key])
}

// ============= Pricing Plans (Unified Bundles) =============

model pricing_plans {
  id                     Int      @id @default(autoincrement())
  code                   String?  @unique
  name                   String
  description            String?
  price                  Decimal  @db.Decimal(10, 2)
  bundle_type            String   @default("credits") // credits, subscription, hybrid
  duration_days          Int? // for subscription/hybrid bundles
  credits_included       Int      @default(0)
  credit_type            String   @default("permanent") // permanent, expiring
  credit_expiry_days     Int? // days until credits expire after approval (null = permanent)
  is_active              Boolean  @default(true)
  is_popular             Boolean  @default(false)
  discount               Int      @default(0)
  order                  Int      @default(0)
  allowed_payment_method String   @default("xendit") // comma-separated: xendit, manual
  allowed_features       Json     @default("[]")    // array of feature keys this plan grants
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now())

  user_purchases user_purchases[]
  user_subscriptions user_subscriptions[]

  @@index([is_active])
  @@index([bundle_type])
  @@index([order])
  @@index([name])
  @@index([code])
  @@index([is_active, bundle_type, order])
}

model user_purchases {
  id              Int      @id @default(autoincrement())
  user_id         Int
  pricing_plan_id Int
  bundle_type     String // credits, subscription, hybrid
  purchase_date   DateTime @default(now())

  // Payment fields
  payment_status    String  @default("completed")
  payment_method    String?
  payment_reference String? // Xendit invoice ID or manual payment reference
  amount_paid       Decimal @db.Decimal(10, 2)
  // Payment evidence is stored via attachments table with name="payment_evidence"

  // Buyer contact info (collected at checkout)
  phone_number String?
  university   String?

  // Snapshot of plan details at time of purchase
  duration_days      Int?
  credits_included   Int?
  credit_type        String?
  credit_expiry_days Int?
  allowed_features   Json @default("[]")

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user         users         @relation(fields: [user_id], references: [id])
  pricing_plan pricing_plans @relation(fields: [pricing_plan_id], references: [id])

  @@index([user_id])
  @@index([pricing_plan_id])
  @@index([bundle_type])
  @@index([payment_status])
}

