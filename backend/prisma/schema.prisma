  created_at     DateTime @default(now())
  updated_at     DateTime @default(now())
  is_deleted     Boolean  @default(false)

  users    users               @relation(fields: [user_id], references: [id])
  tabs     skripsi_tabs[]
  settings skripsi_set_settings?

  @@index([user_id])
  @@index([is_deleted])
  @@index([title(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops"))], type: Gin, map: "skripsi_sets_search_gin_idx")
}

model skripsi_set_settings {
  id                    Int      @id @default(autoincrement())
  set_id                Int      @unique
  selected_domains      Json     @default("[]")
  domain_filter_enabled Boolean  @default(true)
  selected_journals     Json     @default("[]") // Array of journal name strings for tutor users
  latest_years          Int?
  year_from             Int?
  year_to               Int?
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now())

  skripsi_set skripsi_sets @relation(fields: [set_id], references: [id])

  @@index([set_id])
}

model skripsi_journal_names {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

model skripsi_tabs {
  id         Int      @id @default(autoincrement())
  set_id     Int
  tab_type   String // 'ai_researcher_1', 'ai_researcher_2', 'ai_researcher_3', 'paraphraser', 'diagram_builder'
  title      String?
  content    String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  skripsi_set skripsi_sets       @relation(fields: [set_id], references: [id])
  messages    skripsi_messages[]
  diagrams    skripsi_diagrams[]

  @@index([set_id])
  @@index([tab_type])
}

model skripsi_messages {
  id          Int      @id @default(autoincrement())
  tab_id      Int
  sender_type String // 'user' or 'ai'
  content     String   @db.Text
  mode_type   String   @default("research") // 'research', 'validated'
  status      String   @default("streaming") // 'streaming', 'completed', 'truncated'
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  skripsi_tab             skripsi_tabs             @relation(fields: [tab_id], references: [id])
  skripsi_message_sources skripsi_message_sources[]

  @@index([tab_id])
  @@index([sender_type])
  @@index([status])
  @@index([mode_type])
}

model skripsi_message_sources {
  id          Int      @id @default(autoincrement())
  message_id  Int
  source_type String // 'web_search'
  title       String
  content     String   @db.Text
  url         String?
  score       Float? // Similarity/relevance score
  created_at  DateTime @default(now())

  skripsi_message skripsi_messages @relation(fields: [message_id], references: [id])

  @@index([message_id])
  @@index([source_type])
}

model skripsi_diagrams {
  id              Int      @id @default(autoincrement())
  tab_id          Int
  diagram_type    String?  // 'flowchart', 'mindmap', etc. (nullable for manual diagrams)
  detail_level    String?  // 'simple', 'medium', 'detailed' (nullable for manual diagrams)
  orientation     String?  // 'vertical', 'horizontal' (nullable for manual diagrams)
  layout_style    String?  // 'branch', 'linear', 'tree' (nullable for manual diagrams)
  description     String?  @db.Text // User's input description (nullable for manual diagrams)
  diagram_data    String   @db.Text // Excalidraw JSON
  creation_method String   @default("ai_generated") // 'ai_generated' or 'manual'
  credits_used    Decimal  @default(0) @db.Decimal(10, 2)
  created_at      DateTime @default(now())

  skripsi_tab skripsi_tabs @relation(fields: [tab_id], references: [id])

  @@index([tab_id])
  @@index([diagram_type])
  @@index([created_at])
  @@index([creation_method])
}

model skripsi_constants {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  @@index([key])
}

// ============= OSCE Practice Feature =============

model osce_topics {
  id                      Int      @id @default(autoincrement())
  unique_id               String   @unique @default(uuid())
  title                   String
  description             String?
  scenario                String   @db.Text // The OSCE case/scenario
  guide                   String?  @db.Text // Guide or instructions for students
  context                 String?  @db.Text // Additional context or background
  answer_key              String?  @db.Text // Expected answers or key points
  knowledge_base          Json? // Key-value pairs of knowledge items
  physical_exam_guideline String?  @db.Text // Guideline for physical examination tab
  ai_model                String // AI model for this topic (e.g., 'gemini-1.5-pro', 'gpt-4o')
  osce_rubric_id          Int
  duration_minutes        Int // Recommended practice duration
  status                  String   @default("draft") // draft, published
  created_by              Int
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now())

  osce_topic_tags               osce_topic_tags[]
  osce_sessions                 osce_sessions[]
  osce_topic_observations       osce_topic_observations[]
  osce_rubric                   osce_rubrics?                   @relation(fields: [osce_rubric_id], references: [id])
  osce_session_rubric_snapshots osce_session_rubric_snapshots[]

  @@index([created_by])
  @@index([osce_rubric_id])
  @@index([status])
  @@index([title(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops")), scenario(ops: raw("gin_trgm_ops"))], type: Gin, map: "osce_topics_search_gin_idx")
}

model osce_topic_tags {
  id         Int      @id @default(autoincrement())
  topic_id   Int
  tag_id     Int
  created_at DateTime @default(now())

  osce_topic osce_topics @relation(fields: [topic_id], references: [id])
  tags       tags        @relation(fields: [tag_id], references: [id])

  @@unique([topic_id, tag_id])
  @@index([topic_id])
  @@index([tag_id])
}

model osce_rubrics {
  id         Int      @id @default(autoincrement())
  name       String // e.g., "LABORATORIUM", "RADIOLOGI", etc.
  content    String   @db.Text // e.g., "LABORATORIUM", "RADIOLOGI", etc.
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  osce_topics                   osce_topics[]
  osce_session_rubric_snapshots osce_session_rubric_snapshots[]

  @@unique([name])
}

model osce_observation_groups {
  id         Int      @id @default(autoincrement())
  name       String // e.g., "LABORATORIUM", "RADIOLOGI", etc.
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  osce_observations osce_observations[]
}

model osce_observations {
  id         Int      @id @default(autoincrement())
  group_id   Int // Reference to observation group
  name       String // e.g., "ASTO", "Analisis LCS", "Apusan Darah Tepi"
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  osce_observation_group  osce_observation_groups   @relation(fields: [group_id], references: [id])
  osce_topic_observations osce_topic_observations[]

  @@index([group_id])
}

// Junction table linking topics to observations with additional context
model osce_topic_observations {
  id                      Int      @id @default(autoincrement())
  topic_id                Int
  observation_id          Int
  observation_text        String?  @db.Text // Context/description for this observation in this topic
  requires_interpretation Boolean  @default(false) // Whether user needs to interpret the observation
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now())

  osce_topic       osce_topics       @relation(fields: [topic_id], references: [id])
  osce_observation osce_observations @relation(fields: [observation_id], references: [id])

  @@unique([topic_id, observation_id])
  @@index([topic_id])
  @@index([observation_id])
}

model osce_sessions {
  id                  Int       @id @default(autoincrement())
  unique_id           String    @unique @default(uuid())
  user_id             Int
  osce_topic_id       Int // Reference to original topic (for admin purposes)
  status              String    @default("created") // created, started, completed
  time_taken          Int       @default(0) // Actual time spent by user
  total_score         Int?
  max_score           Int?
  ai_feedback         String?   @db.Text // Overall feedback from AI
  credits_used        Int       @default(0)
  observations_locked Boolean   @default(false) // Whether user has saved observations (cannot change after)
  metadata            Json?     // Session metadata (e.g., stt_provider, browser info, etc.)
  scheduled_end_at    DateTime? // When the session is expected to end (based on duration)
  started_at          DateTime? // When the session actually started (after preparation)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now())

  user                                     users                                      @relation(fields: [user_id], references: [id])
  osce_topic                               osce_topics                                @relation(fields: [osce_topic_id], references: [id])
  osce_session_rubric_snapshots            osce_session_rubric_snapshots[]
  osce_session_tag_snapshots               osce_session_tag_snapshots[]
  osce_session_topic_snapshot              osce_session_topic_snapshots?
  osce_session_observation_group_snapshots osce_session_observation_group_snapshots[]
  osce_session_observations                osce_session_observations[]
  osce_session_messages                    osce_session_messages[]
  osce_session_physical_interactions       osce_session_physical_interactions[]
  osce_session_diagnoses                   osce_session_diagnoses[]
  osce_session_therapies                   osce_session_therapies[]

  @@index([unique_id])
  @@index([user_id])
  @@index([osce_topic_id])
  @@index([status])
}

// Snapshot of topic data at session creation time
model osce_session_topic_snapshots {
  id                      Int      @id @default(autoincrement())
  osce_session_id         Int      @unique
  title                   String
  description             String?
  scenario                String   @db.Text
  guide                   String?  @db.Text
  context                 String?  @db.Text
  answer_key              String?  @db.Text
  physical_exam_guideline String?  @db.Text
  knowledge_base          Json?
  ai_model                String
  duration_minutes        Int
  created_at              DateTime @default(now())

  osce_session osce_sessions @relation(fields: [osce_session_id], references: [id])

  @@index([osce_session_id])
}

model osce_session_tag_snapshots {
  id              Int @id @default(autoincrement())
  osce_session_id Int
  tag_id          Int

  osce_session osce_sessions @relation(fields: [osce_session_id], references: [id])
  tags         tags          @relation(fields: [tag_id], references: [id])

  @@index([osce_session_id, tag_id])
  @@index([tag_id])
}

// Snapshot of observation groups at session creation time
model osce_session_observation_group_snapshots {
  id               Int       @id @default(autoincrement())
  osce_session_id  Int
  group_id         Int // Original group ID for reference
  group_name       String // Snapshot of group name
  group_created_at DateTime? // Snapshot of original created_at
  group_updated_at DateTime? // Snapshot of original updated_at
  created_at       DateTime  @default(now())

  osce_session                       osce_sessions                        @relation(fields: [osce_session_id], references: [id])
  osce_session_observation_snapshots osce_session_observation_snapshots[]

  @@index([osce_session_id, group_name])
  @@index([group_id])
}

// Snapshot of observations at session creation time
model osce_session_observation_snapshots {
  id                      Int       @id @default(autoincrement())
  group_snapshot_id       Int // Reference to group snapshot
  observation_id          Int?      @default(0) // Original observation ID
  observation_group_id    Int? // Snapshot of original group_id from observation
  observation_name        String?   @default("") // Snapshot of observation name
  observation_created_at  DateTime? // Snapshot of original observation created_at
  observation_updated_at  DateTime? // Snapshot of original observation updated_at
  observation_text        String?   @db.Text // Snapshot of observation context/description from topic
  requires_interpretation Boolean   @default(false) // Snapshot of interpretation requirement from topic
  topic_observation_order Int       @default(0) // Snapshot of order from topic
  created_at              DateTime  @default(now())

  group_snapshot       osce_session_observation_group_snapshots @relation(fields: [group_snapshot_id], references: [id])
  session_observations osce_session_observations[]

  @@index([observation_id])
  @@index([group_snapshot_id, observation_name])
}

model osce_session_rubric_snapshots {
  id              Int      @id @default(autoincrement())
  osce_session_id Int
  rubric_id       Int
  name            String
  content         String   @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  osce_topics osce_topics[]

  osce_rubric  osce_rubrics?  @relation(fields: [rubric_id], references: [id])
  osce_session osce_sessions? @relation(fields: [osce_session_id], references: [id])

  @@index([rubric_id])
  @@index([osce_session_id])
}

// User's interaction with observations during the session
model osce_session_observations {
  id                      Int      @id @default(autoincrement())
  osce_session_id         Int
  observation_snapshot_id Int // Reference to observation snapshot
  interpretation          String?  @db.Text // Optional notes about this observation
  created_at              DateTime @default(now())

  osce_session         osce_sessions                      @relation(fields: [osce_session_id], references: [id])
  observation_snapshot osce_session_observation_snapshots @relation(fields: [observation_snapshot_id], references: [id])

  @@unique([osce_session_id, observation_snapshot_id])
  @@index([osce_session_id])
  @@index([observation_snapshot_id])
}

model osce_session_messages {
  id              Int      @id @default(autoincrement())
  osce_session_id Int
  sender_type     String // 'user' or 'ai'
  content         String   @db.Text
  credits_used    Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  osce_session osce_sessions @relation(fields: [osce_session_id], references: [id])

  @@index([osce_session_id])
  @@index([sender_type])
  @@index([created_at])
}

model osce_session_physical_interactions {
  id              Int      @id @default(autoincrement())
  osce_session_id Int
  content         String   @db.Text
  sender_type     String // 'user' or 'ai'
  credits_used    Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  osce_session osce_sessions @relation(fields: [osce_session_id], references: [id])

  @@index([osce_session_id])
  @@index([sender_type])
  @@index([created_at])
}

model osce_session_diagnoses {
  id              Int      @id @default(autoincrement())
  osce_session_id Int      @unique
  diagnosis       Json     // Stores { utama: string, pembanding: string[] }
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  osce_session osce_sessions @relation(fields: [osce_session_id], references: [id])

  @@index([osce_session_id])
}

model osce_session_therapies {
  id              Int      @id @default(autoincrement())
  osce_session_id Int      @unique
  therapy         Json     // Can store string or array
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  osce_session osce_sessions @relation(fields: [osce_session_id], references: [id])

  @@index([osce_session_id])
}

// ============= Webinar Feature =============

model webinar_events {
  id           Int       @id @default(autoincrement())
  unique_id    String    @unique @default(uuid())
  title        String
  description  String?   @db.Text
  speakers     Json?     // array of { name, bio }
  benefits     String?   @db.Text
  suitable_for Json?     // array of strings
  join_url              Json      // array of { label, url }
  start_at              DateTime
  end_at                DateTime?
  registration_start_at DateTime
  registration_end_at   DateTime
  status                String    @default("draft") // draft, published, cancelled
  is_deleted   Boolean   @default(false)
  deleted_at   DateTime?
  created_by   Int
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())

  webinar_registrations webinar_registrations[]

  @@index([status])
  @@index([is_deleted])
  @@index([start_at])
}

model webinar_registrations {
  id          Int       @id @default(autoincrement())
  unique_id   String    @unique @default(uuid())
  webinar_id  Int
  user_id     Int
  status      String    @default("pending") // pending, approved, rejected
  admin_notes String?
  reviewed_by Int?
  reviewed_at DateTime?
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())

  webinar_event webinar_events @relation(fields: [webinar_id], references: [id])

  @@index([webinar_id])
  @@index([user_id])
  @@index([status])
}

// ============= Events Feature =============

model events {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  title        String
  description  String?   @db.Text
  start_at     DateTime?
  end_at       DateTime?
  registration_start_at DateTime?
  registration_end_at   DateTime?
  status       String    @default("draft") // draft, published, cancelled
  // Quota disbursed on approval
  credits_on_approval Int     @default(0)
  credit_type         String  @default("permanent") // permanent, expiring
  credit_expiry_days  Int?
  allowed_features    Json    @default("[]") // [{ key, durationDays }]
  is_deleted   Boolean   @default(false)
  deleted_at   DateTime?
  created_by   Int
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())

  event_registrations event_registrations[]

  @@index([status])
  @@index([is_deleted])
  @@index([start_at])
}

model event_registrations {
  id          Int       @id @default(autoincrement())
  unique_id   String    @unique @default(uuid())
  event_id    Int
  user_id     Int
  status      String    @default("pending") // pending, approved, rejected
  admin_notes String?
  reviewed_by Int?
  reviewed_at DateTime?
  credits_granted   Int?
  features_granted  Json?
  is_deleted  Boolean   @default(false)
  deleted_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())

  event events @relation(fields: [event_id], references: [id])

  @@index([event_id])
  @@index([user_id])
  @@index([status])
}

// ============= Banner Feature =============

model banners {
  id             Int       @id @default(autoincrement())
  unique_id      String    @unique @default(uuid())
  title          String
  description    String?   @db.Text
  redirect_url   String
  redirect_label String?
  gradient_start String?
  gradient_end   String?
  is_active      Boolean   @default(false)
  order          Int       @default(0)
  is_deleted     Boolean   @default(false)
  deleted_at     DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())

  @@index([is_active])
  @@index([is_deleted])
  @@index([order])
}

// ============= Challenge Feature =============

model challenges {
  id                       Int       @id @default(autoincrement())
  unique_id                String    @unique @default(uuid())
  title                    String
  description              String?   @db.Text
  scoring_type             String    // "classic" | "blitz"
  duration_seconds         Int
  total_questions          Int
  base_points_per_correct  Int       @default(1000)
  seconds_per_question     Int       @default(30)
  max_special_per_session  Int       @default(0)
  special_duration_seconds Int       @default(120)
  status                   String    @default("draft") // "draft" | "active" | "inactive"
  start_at                 DateTime?
  end_at                   DateTime?
  badges_disbursed         Boolean   @default(false)
  participant_count        Int       @default(0)
  question_pool_count      Int       @default(0)
  is_deleted               Boolean   @default(false)
  deleted_at               DateTime?
  created_by               Int
  created_at               DateTime  @default(now())
  updated_at               DateTime  @default(now())

  challenge_questions challenge_questions[]
  challenge_badges    challenge_badges[]
  challenge_sessions  challenge_sessions[]
  challenge_tags      challenge_tags[]
  challenge_rewards   challenge_rewards[]

  @@index([status])
  @@index([is_deleted])
  @@index([start_at])
  @@index([scoring_type])
  @@index([badges_disbursed])
}

model challenge_questions {
  id                   Int      @id @default(autoincrement())
  unique_id            String   @unique @default(uuid())
  challenge_id         Int
  question             String?  @db.Text
  options              Json
  correct_option_index Int
  explanation          String?  @db.Text
  order                Int      @default(0)
  is_special           Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now())

  challenge             challenges                @relation(fields: [challenge_id], references: [id])
  challenge_session_answers challenge_session_answers[]

  @@index([challenge_id])
  @@index([order])
}

model challenge_badges {
  id           Int      @id @default(autoincrement())
  unique_id    String   @unique @default(uuid())
  challenge_id Int
  name         String
  description  String?
  min_rank     Int
  max_rank     Int
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())

  challenge challenges @relation(fields: [challenge_id], references: [id])

  @@index([challenge_id])
  @@index([min_rank])
}

model challenge_sessions {
  id                 Int       @id @default(autoincrement())
  unique_id          String    @unique @default(uuid())
  challenge_id       Int
  user_id            Int
  question_ids       Json
  status             String    @default("in_progress") // "in_progress" | "completed"
  score              Float?
  current_streak     Int       @default(0)
  correct_count      Int?
  total_time_seconds Float?
  started_at         DateTime  @default(now())
  completed_at       DateTime?
  earned_badge_id    Int?
  final_rank         Int?
  reward_read        Boolean   @default(false)
  created_at         DateTime  @default(now())

  challenge                      challenges                         @relation(fields: [challenge_id], references: [id])
  users                          users                              @relation(fields: [user_id], references: [id])
  challenge_session_answers      challenge_session_answers[]
  challenge_reward_disbursements challenge_reward_disbursements[]

  @@unique([challenge_id, user_id])
  @@index([challenge_id])
  @@index([user_id])
  @@index([status])
  @@index([score])
  @@index([earned_badge_id])
}

model challenge_rewards {
  id                              Int                              @id @default(autoincrement())
  challenge_id                    Int
  title                           String
  description                     String?
  status                          String                           @default("pending")
  min_rank                        Int?
  max_rank                        Int?
  created_at                      DateTime                         @default(now())
  updated_at                      DateTime                         @updatedAt
  challenges                      challenges                       @relation(fields: [challenge_id], references: [id])
  challenge_reward_disbursements  challenge_reward_disbursements[]
}

model challenge_reward_disbursements {
  id                   Int                @id @default(autoincrement())
  challenge_reward_id  Int
  challenge_session_id Int
  status               String             @default("pending")
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  challenge_rewards    challenge_rewards  @relation(fields: [challenge_reward_id], references: [id], onDelete: Cascade)
  challenge_sessions   challenge_sessions @relation(fields: [challenge_session_id], references: [id], onDelete: Cascade)

  @@unique([challenge_reward_id, challenge_session_id])
}

model challenge_session_answers {
  id                    Int      @id @default(autoincrement())
  session_id            Int
  question_id           Int
  selected_option_index Int?
  is_correct            Boolean
  time_taken_seconds    Float?
  created_at            DateTime @default(now())

  challenge_session  challenge_sessions  @relation(fields: [session_id], references: [id])
  challenge_question challenge_questions @relation(fields: [question_id], references: [id])

  @@unique([session_id, question_id])
  @@index([session_id])
  @@index([question_id])
}

model challenge_tags {
  id           Int      @id @default(autoincrement())
  challenge_id Int
  tag_id       Int
  created_at   DateTime @default(now())

  challenge challenges @relation(fields: [challenge_id], references: [id])
  tags      tags       @relation(fields: [tag_id], references: [id])

  @@unique([challenge_id, tag_id])
  @@index([challenge_id])
  @@index([tag_id])
}

model webhook_logs {
  id                Int      @id @default(autoincrement())
  source            String   // 'xendit_invoice', 'xendit_va', 'midtrans'
  event_type        String?  // 'PAID', 'EXPIRED', 'SETTLEMENT', etc.
  payment_reference String?  // invoice ID / external_id / order ID
  payload           Json     // full raw webhook body
  status            String   // 'processed', 'not_found', 'error'
  error_message     String?
  created_at        DateTime @default(now())

  @@index([source])
  @@index([payment_reference])
  @@index([status])
  @@index([created_at])
}


model user_recently_viewed {
  id          Int      @id @default(autoincrement())
  user_id     Int
  record_type String
  record_id   Int
  metadata    Json?
  viewed_at   DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, record_type, record_id])
  @@index([user_id, record_type, viewed_at(sort: Desc)])
}

model user_favorites {
  id          Int      @id @default(autoincrement())
  user_id     Int
  record_type String
  record_id   Int
  created_at  DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, record_type, record_id])
  @@index([user_id, record_type])
}
