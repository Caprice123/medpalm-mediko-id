  description         String?
  clinical_references String[] @default([])
  formula             String? // Deprecated: use calculator_results instead
  result_label        String? // Deprecated: use calculator_results instead
  result_unit         String? // Deprecated: use calculator_results instead
  status              String   @default("draft") // draft, published
  is_deleted          Boolean  @default(false)
  deleted_at          DateTime?
  created_by          Int
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now())

  calculator_fields          calculator_fields[]
  calculator_results         calculator_results[]
